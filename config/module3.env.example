# Optional Module 3 variables. Copy needed lines into /etc/demo-autoconfig/config.env.

# General
DOMAIN="au-team.irpo"
ADMIN_PASSWORD="P@ssw0rd"
HQ_SRV_IP="192.168.100.2"
HQ_RTR_HQ_IP="192.168.100.1"
HQ_RTR_WAN_IP="172.16.1.2"
BR_RTR_WAN_IP="172.16.2.2"
BR_RTR_LAN_IP="192.168.255.1"
BR_SRV_IP="192.168.255.2"
HQ_CLI_IP="192.168.200.2"
HQ_CLI_NET="192.168.200.0/27"
HQ_NETS="192.168.100.0/28 192.168.200.0/27 192.168.250.0/29"
BR_NETS="192.168.255.0/28"

# SSH
SSH_USER="sshuser"
SSH_PASSWORD="P@ssw0rd"
SSH_SERVER_PORT="2026"
SSH_ROUTER_USER="net_admin"
SSH_ROUTER_PASSWORD="P@ssw0rd"
SSH_ROUTER_PORT="22"
SSH_CLIENT_PORT="22"

# Additional.iso
ISO_MOUNTPOINT="/mnt/additional"
USERS_CSV_PATH="Users.csv"

# CA/HTTPS
CA_DIR="/etc/demo-ca"
CA_DAYS="30"
MONITOR_USER="admin"
MONITOR_PASSWORD="P@ssw0rd"

# IPsec
IPSEC_PSK="P@ssw0rd"

# Firewall/NAT
WAN_IFACE="ens33"
NAT_LAN_CIDRS="192.168.100.0/28 192.168.200.0/27 192.168.250.0/29 192.168.255.0/28"

# Monitoring
MONITOR_PORT="80"

# Fail2ban
FAIL2BAN_SSH_PORT="2026"

# Backup via Borg as a safe open-source analogue
BACKUP_REPO="backupsvc@192.168.200.2:/backup/irpo/borg"
BACKUP_PASSPHRASE="P@ssw0rd"

# Ansible task 8 credentials for HQ-CLI
HQ_CLI_ANSIBLE_USER="user"
HQ_CLI_ANSIBLE_PASSWORD="root"

# ISP orchestration mode for quick repeated testing.
# If ROLE="ISP" and this is yes, Module 3 runs remotely on HQ-SRV, HQ-CLI, BR-SRV, HQ-RTR, BR-RTR,
# then runs ISP nginx HTTPS proxy locally.
MODULE3_ORCHESTRATE_FROM_ISP="yes"
MODULE3_REMOTE_ROLES="HQ-SRV HQ-CLI BR-SRV HQ-RTR BR-RTR"
MODULE3_REMOTE_TMP_ROOT="/tmp/demo-module3-remote"

# Set this to yes only on remote runs to prevent recursive orchestration.
DEMO_SKIP_MODULE3_ORCHESTRATION="no"
